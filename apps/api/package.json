{
  "name": "@queue-tracker/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "setup:employee": "tsx --env-file=../../.env src/scripts/setupEmployee.ts",
    "seed:test": "tsx --env-file=../../.env src/scripts/seedTestData.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@queue-tracker/shared": "0.1.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@hono/node-server": "^1.16.0",
    "@types/node": "^22.20.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
